{
  "name": "vsxdt",
  "displayName": "VSCode Develop Tools",
  "description": "Eval .code.js selections and inject inputs into a Chrome debugging target.",
  "icon": "assets/icon.png",
  "version": "1.0.0",
  "publisher": "Lenik",
  "repository": {
    "type": "git",
    "url": "https://github.com/lenik/vsxdt.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:vsxdt.evalSelection",
    "onCommand:vsxdt.showInputInjectDialog",
    "onCommand:vsxdt.toggleProxies"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vsxdt.evalSelection",
        "title": "DevTools: Eval Selection"
      },
      {
        "command": "vsxdt.showInputInjectDialog",
        "title": "DevTools: Show Input Inject Dialog"
      },
      {
        "command": "vsxdt.toggleProxies",
        "title": "DevTools: Cycle Proxy"
      }
    ],
    "keybindings": [
      {
        "command": "vsxdt.evalSelection",
        "key": "f5",
        "when": "editorTextFocus && editorHasSelection && resourceFilename =~ /.*\\.code\\.js$/"
      },
      {
        "command": "vsxdt.toggleProxies",
        "key": "alt+shift+p"
      }
    ],
    "configurationDefaults": {
      "files.associations": {
        "*.code.js": "javascript"
      }
    },
    "configuration": {
      "title": "VSCode DevTools Tools",
      "properties": {
        "vsxdt.chromeHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Chrome remote debugging host."
        },
        "vsxdt.chromePort": {
          "type": "number",
          "default": 9222,
          "description": "Chrome remote debugging port."
        },
        "vsxdt.targetUrlIncludes": {
          "type": "string",
          "default": "",
          "description": "Optional substring used to choose a page target."
        },
        "vsxdt.maxResultLength": {
          "type": "number",
          "default": 20000,
          "description": "Maximum formatted eval result length."
        },
        "vsxdt.proxyList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Proxy URLs used by DevTools: Cycle Proxy (vsxdt.toggleProxies) applies each entry to VS Code \"http.proxy\" in order, then clears it once after the last entry, then repeats."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run bundle -- --production",
    "compile": "tsc -p ./",
    "bundle": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.8.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.3"
  }
}
