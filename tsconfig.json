{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "outDir": "dist",
    "lib": ["ES2022"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "types": ["node", "vscode"],
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "skipLibCheck": true
  },
  "include": ["src"]
}